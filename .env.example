# Docker 环境变量示例
# 复制此文件为 .env 并修改对应的值

# 时区设置
TZ=Asia/Shanghai

# Python 输出不缓冲
PYTHONUNBUFFERED=1

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Web 服务端口（默认 8080）
WEB_PORT=8080

# Web 服务主机（容器内使用 0.0.0.0）
WEB_HOST=0.0.0.0

# 挂载路径配置
# 下载目录（宿主机路径）
DOWNLOADS_PATH=/path/to/downloads

# 媒体库目录（宿主机路径）
MEDIA_PATH=/path/to/media

# 数据目录（宿主机路径）
DATA_PATH=./data

# 日志目录（宿主机路径）
LOGS_PATH=./logs

# STRM 输出目录（宿主机路径）
STRM_PATH=./strm

# Docker 镜像配置
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE=video-organizer
DOCKER_TAG=latest
