# Dockerfile - 直接运行版本
FROM python:3.12-alpine

# 安装系统依赖
RUN apk add --no-cache \
    build-base \
    wget \
    git

# 设置工作目录
WORKDIR /app

# 复制所有文件
COPY . .

# 安装依赖
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# 直接运行Python脚本
CMD ["python", "run_organizer.py"]